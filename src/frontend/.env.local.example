# Base URL for static assets (component previews, images, downloads).
# On Uberspace, Next.js runs behind an Apache reverse proxy. Serving large static files
# through that proxy causes 502 timeouts. Setting this to a URL that is served directly
# by Apache (e.g. your ~/html/ directory) bypasses the proxy for asset requests.
# On localhost this variable is ignored and Next.js serves assets as usual.
NEXT_PUBLIC_STATIC_BASE_URL=https://your.static.assets.address.com

# MONGODB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/yourdatabase?retryWrites=true&w=majority
MONGODB_DB="yourdatabase"
MONGODB_USERCOLLECTION="users"

# NEXTAUTH
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=JWTSecretShouldGoHere

# FASTAPI
FASTAPI_URL=https://your-api.address.com
API_SECRET=JWTSecretShouldGoHere
API_TOKEN_TIMEOUT_MINS=59
