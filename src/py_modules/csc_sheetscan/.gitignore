

## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Visual Studio Code directory
.vscode/

# Python Virtual Environment
.venv/
_backup_.venv

# CACHED PYTHON FILES
__pycache__/

# COVERAGE FILES
.coverage

# VIZ FOLDER
/viz/

# IMAGE FOLDERS
/src/csc_sheetscan/sheets/inputdata/queue/chess/*/
/src/csc_sheetscan/sheets/inputdata/queue/chess/*.jpg

/src/csc_sheetscan/sheets/inputdata/queue/raw/*/
/src/csc_sheetscan/sheets/inputdata/queue/raw/*.jpg

/src/csc_sheetscan/sheets/inputdata/queue/undist/*/
/src/csc_sheetscan/sheets/inputdata/queue/undist/*.jpg

/src/csc_sheetscan/sheets/inputdata/datasets/*/
/src/csc_sheetscan/sheets/inputdata/datasets/*.jpg

/src/csc_sheetscan/label/output/*/
/src/csc_sheetscan/label/output/*.jpg

# OUTPUT DATA FOLDER
/src/csc_sheetscan/sheets/outputdata/processed/*/

/src/csc_sheetscan/sheets/outputdata/sheets/*/
/src/csc_sheetscan/sheets/outputdata/sheets/*.json

/src/csc_sheetscan/sheets/outputdata/processed/*/
/src/csc_sheetscan/sheets/outputdata/processed/*.zip

# DATABASE CONFIG FILE FOR DEVELOPMENT
/src/csc_sheetscan/dbclient/config/dbconfig.json

# MISC
_archive
urban_production_env.yml
ddu_ias_research_env_extended.yml
cscscan.code-workspace
*.egg-info

src/csc_sheetscan/dbclient/configdata/dbconfig.json
