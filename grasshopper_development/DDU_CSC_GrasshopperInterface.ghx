                  <items count="13">
                    <item name="CodeInput" type_name="gh_string" type_code="10">"""
Custom Preview with Lineweights.
    Inputs:
        Geometry: The geometry to preview. {list, GeometryBase}
        Color: The preview color per geometry item. {list, System.Drawing.Color}
        Thickness: The thickness of the wire display. {item, int}
    Remarks:
        Author: Max Eschenbach
        License: MIT License
        Version: 231122
"""

# PYTHON STANDARD LIBRARY IMPORTS
from __future__ import division, print_function
import json
import math

# GHPYTHON SDK IMPORTS
from ghpythonlib.componentbase import executingcomponent as component
import Grasshopper, GhPython
import System
import Rhino
import rhinoscriptsyntax as rs

# GHENV COMPONENT SETTINGS
ghenv.Component.Name = "CustomPreviewLineweights"
ghenv.Component.NickName = "CPL"
ghenv.Component.Category = "FindersKeepers"
ghenv.Component.SubCategory = "4 Visualisation"

class CustomPreviewLineweights(component):
    
    def __init__(self):
        super(CustomPreviewLineweights, self).__init__()
        
        self.draw_lines = System.Collections.Generic.List[Rhino.Geometry.Line]()
        self.draw_curves = []
        self.draw_color = []
        self.draw_thickness = None
    
    
    def RunScript(self, Geometry, Color, Thickness):
        
        self.draw_lines = System.Collections.Generic.List[Rhino.Geometry.Line]()
        self.draw_curves = []
        self.draw_color = None
        self.draw_thickness = None
        
        if not Color:
            self.draw_color = [System.Drawing.Color.Black]
        else:
            self.draw_color = Color
        
        if not Thickness:
            self.draw_thickness = 1
        else:
            self.draw_thickness = Thickness
        
        if Geometry:
            for i, geo in enumerate(Geometry):
                if isinstance(geo, Rhino.Geometry.Line):
                    self.draw_curves.Add(Rhino.Geometry.LineCurve(geo))
                elif isinstance(geo, Rhino.Geometry.Curve):
                    self.draw_curves.append(geo)
                elif isinstance(geo, Rhino.Geometry.LineCurve):
                    self.draw_curves.Add(geo)
                elif isinstance(geo, Rhino.Geometry.Rectangle3d):
                    self.draw_curves.append(geo.ToNurbsCurve())
                else:
                    print(type(geo))
    
    
    def get_ClippingBox(self):
        return Rhino.Geometry.BoundingBox()
    
    
    def DrawViewportWires(self, arg):
        try:
            for i, crv in enumerate(self.draw_curves):
                if i &gt;= len(self.draw_color):
                    col = self.draw_color[-1]
                else:
                    col = self.draw_color[i]
                if not col:
                    rml = self.RuntimeMessageLevel.Remark
                    self.AddRuntimeMessage(rml, 'Expected Color, got NoneType! '
                                                 'Substituting with Black...')
                    col = System.Drawing.Color.Black
                arg.Display.DrawCurve(crv, col, self.draw_thickness)
        except Exception, e:
            rml = self.RuntimeMessageLevel.Warning
            self.AddRuntimeMessage(rml, 'Error while drawing Preview!')
            # System.Windows.Forms.MessageBox.Show(
            #                     str(e),
            #                     'Error while drawing preview!')
</item>
