

## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Visual Studio Code directory
.vscode/

# Python Virtual Environment
.venv/
_backup_.venv

# ENVIRONMENT FILES
*.env
*.bash_profile
*fastapi.ini

# CACHED PYTHON FILES
__pycache__/

# COVERAGE FILES
.coverage

# reference folder
/reference/

# folder for internal future implementation plans
/future_implementation/

# VIZ FOLDER
/viz/

# COMPONENT GEOMETRY FOLDER
/component_geometry/
/mongodb_backup/

# DATABASE CONFIG FILE FOR DEVELOPMENT
/src/backend/config/dbconfig.json
/src/backend/config/email_config.json
/src/backend/apps/catalog/hash_pwd.py


# OLD FILES FROM NEXTJS14 APP
/src/backend_OLD/
/src/frontend_OLD/

/gh_dev/00_archive/


# MISC
_archive
csc.code-workspace
*.egg-info
src/backend/apps/catalog/test.json
src/backend/logs/fastapi.log
*.3dm.rhl

scripts/**/*.log

# REPO-WIDE LOG OUTPUT (scripts, maintenance, audits)
